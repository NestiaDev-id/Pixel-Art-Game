[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1

[libraries]
linux.debug.x86_64 = "res://bin/libsrc_game.so"
linux.release.x86_64 = "res://bin/libsrc_game.so"
windows.debug.x86_64 = "res://bin/src_game.dll"
windows.release.x86_64 = "res://bin/src_game.dll"
macos.debug = "res://bin/libsrc_game.dylib"
macos.release = "res://bin/libsrc_game.dylib"
